# =============================================================================
# IAMS — .gitignore
# Takoradi Technical University
# =============================================================================


# -----------------------------------------------------------------------------
# Environment & Secrets  ← most important
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.ttu_iams_deepseek_api-keys

# Supabase CLI local secrets (created by `supabase link`)
supabase/.env.local
supabase/.temp/


# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
dist/
dist-ssr/


# -----------------------------------------------------------------------------
# Node / npm
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*


# -----------------------------------------------------------------------------
# Vite
# -----------------------------------------------------------------------------
*.local
.vite/


# -----------------------------------------------------------------------------
# Supabase CLI artefacts
# -----------------------------------------------------------------------------
supabase/.branches/
supabase/squash/
# Note: supabase/.temp/ is already listed above under Secrets


# -----------------------------------------------------------------------------
# OS & Editor
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains IDEs
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
.nvimrc.local

# Emacs
*~
\#*\#


# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log


# -----------------------------------------------------------------------------
# PWA / Service Worker generated files (Vite PWA plugin outputs)
# -----------------------------------------------------------------------------
public/sw.js
public/workbox-*.js
public/sw.js.map
public/workbox-*.js.map


# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/


# -----------------------------------------------------------------------------
# Temporary / scratch
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
