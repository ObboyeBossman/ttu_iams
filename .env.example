# =============================================================================
# IAMS — Environment Variables
# Takoradi Technical University
# =============================================================================
# Copy this file to .env (for local development) and fill in the real values.
#
#   cp .env.example .env
#
# NEVER commit .env to version control — see .gitignore.
# The .env.example file is safe to commit; it contains no secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — Client-side (VITE_ prefix → exposed to the browser bundle)
# -----------------------------------------------------------------------------
# Found in: Supabase Dashboard → Project Settings → API → Project URL / anon key
# These are safe to ship in the browser — they are not secrets.
# Security comes from Row Level Security (RLS) policies, not from hiding these.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key


# -----------------------------------------------------------------------------
# Supabase — Edge Functions (server-side only, never exposed to the browser)
# -----------------------------------------------------------------------------
# Injected automatically by the Supabase runtime when deployed.
# For local development with `supabase functions serve`, these are read from
# supabase/.env.local (created by `supabase link`). Only set them manually
# here if running functions outside the Supabase CLI.

# SUPABASE_URL=https://your-project-ref.supabase.co       # same as VITE_ value
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key         # SECRET — never expose


# -----------------------------------------------------------------------------
# App — Origin restriction for Edge Function CORS
# -----------------------------------------------------------------------------
# Set to your deployed frontend URL to restrict CORS in production.
# In development the functions default to "*" (any origin).
# Example: https://iams.ttu.edu.gh

VITE_APP_URL=http://localhost:5173
# ALLOWED_ORIGIN=https://iams.ttu.edu.gh                 # set on Edge Function env in prod


# -----------------------------------------------------------------------------
# Supabase CLI (local dev only — not used by Vite)
# -----------------------------------------------------------------------------
# Set by `supabase link`; you do not normally need to set these manually.

# SUPABASE_ACCESS_TOKEN=your-personal-access-token        # for supabase CLI auth
# SUPABASE_DB_PASSWORD=your-database-password             # for supabase db push/pull
