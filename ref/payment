**`supabase/rls-policies.sql`** — append at the end:

```sql
-- =============================================================================
-- payments
-- =============================================================================

alter table public.payments enable row level security;

-- A student may read their own payment rows (used by hasPaid() to gate access).
create policy "payments: student reads own"
  on public.payments for select
  using (student_id = auth.uid());

-- Admin reads all payment rows (Finance page).
create policy "payments: admin reads all"
  on public.payments for select
  using (public.current_role() = 'admin');

-- Intentionally no insert/update/delete policy for ANY role, including admin.
-- Every row is written by the verify-paystack Edge Function via the
-- service-role key (bypasses RLS) only after it has independently verified
-- the transaction with Paystack. This removes the "trust the browser"
-- failure mode that the old localStorage fallback had.
