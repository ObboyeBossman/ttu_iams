# =============================================================================
# IAMS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.
# =============================================================================

# ── Supabase (required) ──────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Project URL — safe to expose in the browser (used by Vite)
VITE_SUPABASE_URL=https://your-ref.supabase.co

# Anon / public key — safe to expose in the browser (used by Vite)
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Client-side (VITE_ prefix) — Paystack PUBLIC key. Safe to expose; it can
# only initiate a charge, never move money or verify one on its own.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# Edge Functions only — set to "true" to skip real Paystack verification
# and auto-confirm payments for local dev. Leave unset/false everywhere
# else. Unlike the old implicit fallback, this requires an explicit opt-in.
PAYSTACK_MOCK_MODE=false

# ── Seeder only (NEVER expose this in the browser) ────────────────────────────
# Service role key — full DB access. Used ONLY by scripts/seed-users.mjs.
# Set as a shell export, NOT in .env (keeps it out of any build tooling):
#
#   export SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...
#   node scripts/seed-users.mjs
#
# SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...